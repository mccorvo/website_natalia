# macOS/editor noise
.DS_Store
**/.DS_Store

# Dependencies and generated build output.
**/node_modules/
**/.next/
**/.turbo/
**/dist/
**/build/
**/coverage/
**/.cache/
**/.wrangler/
**/.vercel/
**/.automation-worktrees/

# The backup root is not an npm package; keep the real site lockfile tracked.
/package-lock.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Local secrets. Keep examples tracked.
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
id_rsa*
id_ed25519*

# Nested Git metadata is represented by source files plus bundle files when needed.
**/.git/

